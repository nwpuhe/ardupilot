# ==========================================
# PRSLab_FC Bootloader 专用独立配置
# ==========================================
MCU STM32H7xx STM32H753xx
OSCILLATOR_HZ 16000000
STM32_ST_USE_TIMER 2
APJ_BOARD_ID 1024

# --- 核心：确保 Bootloader 烧录在起始地址 ---
FLASH_RESERVE_START_KB 0
FLASH_BOOTLOADER_LOAD_KB 128
FLASH_SIZE_KB 2048

# --- USB 引脚 ---
SERIAL_ORDER OTG1
PA11 OTG_FS_DM OTG1
PA12 OTG_FS_DP OTG1
PA9 VBUS INPUT OPENDRAIN

# --- SWD 调试引脚 ---
PA13 JTMS-SWDIO SWD
PA14 JTCK-SWCLK SWD